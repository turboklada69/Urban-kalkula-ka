<Window x:Class="Kalkulajda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kalkulačka" Height="600" Width="400">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="79"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Small expression display -->
        <TextBlock x:Name="TxtExpression"
                   Grid.Row="0"
                   Text=""
                   FontSize="16"
                   Foreground="Gray"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Main result display -->
        <TextBlock x:Name="TxtResult"
                   Grid.Row="1"
                   Text="0"
                   FontSize="36"
                   FontWeight="Bold"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Buttons -->
        <UniformGrid Grid.Row="2" Rows="6" Columns="4" Margin="4">
            <!-- Memory / percent / clear row -->
            <Button x:Name="Btn_R0C0" Content="%" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R0C1" Content="CE" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R0C2" Content="C" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R0C3" Content="Del." Margin="4" Click="Button_Click"/>

            <!-- Functions row -->
            <Button x:Name="Btn_R1C0" Content="1/x" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R1C1" Content="sqr()" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R1C2" Content="√" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R1C3" Content="÷" Margin="4" Click="Button_Click"/>

            <!-- Digits and operators -->
            <Button x:Name="Btn_R2C0" Content="7" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R2C1" Content="8" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R2C2" Content="9" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R2C3" Content="x" Margin="4" Click="Button_Click"/>

            <Button x:Name="Btn_R3C0" Content="4" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R3C1" Content="5" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R3C2" Content="6" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R3C3" Content="-" Margin="4" Click="Button_Click"/>

            <Button x:Name="Btn_R4C0" Content="1" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R4C1" Content="2" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R4C2" Content="3" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R4C3" Content="+" Margin="4" Click="Button_Click"/>

            <Button x:Name="Btn_R5C0" Content="+/-" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R5C1" Content="0" Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R5C2" Content="," Margin="4" Click="Button_Click"/>
            <Button x:Name="Btn_R5C3" Content="=" Margin="4" Click="Button_Click"/>
        </UniformGrid>
    </Grid>
</Window>
